# Server
NODE_ENV="development"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# DISABLE_HMR: Set to "true" to disable Vite HMR/file watching.
DISABLE_HMR="false"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY=""

# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL=""

# SUPABASE_ANON_KEY: Your Supabase anonymous key
SUPABASE_ANON_KEY=""

# SUPABASE_KEY: Optional alternate Supabase key read by the server.
SUPABASE_KEY=""

# RAPIDAPI_KEY: Required for live Google Jobs / LinkedIn Jobs RapidAPI calls.
RAPIDAPI_KEY=""

# DECODA_API_KEY: Your Decoda API Key for crawling (optional, will mock otherwise)
DECODA_API_KEY=""

# APIFY_API_TOKEN: Your Apify token
APIFY_API_TOKEN=""
